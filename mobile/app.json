{
  "expo": {
    "name": "SomeKorean",
    "slug": "somekorean",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#2563EB"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.somekorean.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "프로필 사진 및 파일 첨부를 위해 카메라 접근이 필요합니다.",
        "NSPhotoLibraryUsageDescription": "사진 첨부를 위해 갤러리 접근이 필요합니다.",
        "NSLocationWhenInUseUsageDescription": "주변 드라이버 및 지역 정보를 위해 위치 접근이 필요합니다.",
        "NSFaceIDUsageDescription": "빠른 로그인을 위해 Face ID 사용이 필요합니다."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2563EB"
      },
      "package": "com.somekorean.app",
      "versionCode": 1,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "VIBRATE",
        "RECEIVE_BOOT_COMPLETED"
      ],
      "googleServicesFile": "./google-services.json"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#2563EB"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "위치 기반 서비스를 위해 위치 접근이 필요합니다."
        }
      ]
    ],
    "scheme": "somekorean",
    "extra": {
      "eas": {
        "projectId": "somekorean-app"
      }
    }
  }
}
