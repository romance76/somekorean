<template>
  <div class="min-h-screen bg-gray-50 pb-20">
    <div class="max-w-[1200px] mx-auto px-4 pt-4">

      <!-- 로딩 -->
      <div v-if="loading" class="text-center py-20 text-gray-400">불러오는 중...</div>

      <!-- 찾을 수 없음 -->
      <div v-else-if="!club" class="text-center py-20">
        <p class="text-4xl mb-3">😢</p>
        <p class="text-gray-400">동호회를 찾을 수 없습니다.</p>
        <router-link to="/clubs" class="mt-3 inline-block text-blue-600 text-sm hover:underline">목록으로 돌아가기</router-link>
      </div>

      <!-- 본문 -->
      <template v-else>

        <!-- 상단 헤더 -->
        <div class="text-white px-6 py-4 rounded-2xl mb-4"
          :style="`background: linear-gradient(to right, ${gradFrom(club.category)}, ${gradTo(club.category)})`">
          <div class="flex items-center justify-between mb-2">
            <div class="flex items-center gap-2">
              <router-link to="/clubs" class="text-white/70 text-sm hover:text-white transition">← 동호회 목록</router-link>
              <span class="bg-white/20 text-xs px-3 py-1 rounded-full">{{ club.category }}</span>
              <span v-if="club.is_approval" class="bg-white/20 text-xs px-3 py-1 rounded-full">🔒 승인제</span>
            </div>
            <div class="flex items-center gap-2">
              <!-- 공유 버튼만 -->
              <button @click="shareClub"
                class="flex items-center gap-1 text-xs text-white/80 hover:text-white bg-white/10 hover:bg-white/20 px-3 py-1.5 rounded-lg transition">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"/></svg>
                공유
              </button>
            </div>
          </div>
          <h1 class="text-xl font-black leading-tight mb-1">{{ categoryEmoji(club.category) }} {{ club.name }}</h1>
          <div class="flex items-center gap-3 text-sm text-white/80">
            <span v-if="club.region">📍 {{ club.region }}</span>
            <span>👤 {{ club.member_count || members.length }}명</span>
            <span v-if="club.creator">· {{ club.creator.name }}</span>
          </div>
        </div>

        <!-- 2컬럼 레이아웃 -->
        <div class="flex gap-5 items-start">

          <!-- 왼쪽 본문 -->
          <div class="flex-1 min-w-0">

            <!-- 클럽 소개 카드 -->
            <div class="bg-white rounded-2xl shadow-sm p-5 mb-4">
              <div class="flex items-start justify-between gap-4">
                <div class="flex-1">
                  <p class="text-sm text-gray-700 leading-relaxed">{{ club.description }}</p>
                  <div class="flex flex-wrap gap-2 mt-3">
                    <span class="text-xs bg-gray-100 text-gray-600 px-2 py-1 rounded-full">{{ club.category }}</span>
                    <span v-if="club.region" class="text-xs bg-blue-50 text-blue-600 px-2 py-1 rounded-full">{{ club.region }}</span>
                    <span class="text-xs bg-green-50 text-green-600 px-2 py-1 rounded-full">👤 {{ club.member_count || members.length }}명</span>
                  </div>
                </div>
                <!-- 가입/탈퇴/방장 버튼 -->
                <div class="flex flex-col gap-2 flex-shrink-0">
                  <button v-if="!isMember && authStore.isLoggedIn" @click="joinClub"
                    class="flex items-center gap-1 text-xs font-bold bg-blue-600 text-white hover:bg-blue-700 px-4 py-2 rounded-lg transition">
                    {{ club.is_approval ? '🙋 가입 신청' : '✅ 가입하기' }}
                  </button>
                  <button v-else-if="isMember && !isOwner" @click="leaveClub"
                    class="flex items-center gap-1 text-xs text-gray-600 hover:text-red-600 bg-gray-100 hover:bg-red-50 px-4 py-2 rounded-lg transition">
                    탈퇴
                  </button>
                  <span v-else-if="isOwner"
                    class="text-xs bg-blue-50 text-blue-600 px-4 py-2 rounded-lg font-semibold text-center">👑 방장</span>
                  <router-link v-else to="/login"
                    class="text-xs bg-blue-600 text-white hover:bg-blue-700 px-4 py-2 rounded-lg transition font-bold text-center">
                    로그인 후 가입
                  </router-link>
                </div>
              </div>
            </div>

            <!-- 멤버 목록 -->
            <div v-if="members.length" class="bg-white rounded-2xl shadow-sm overflow-hidden mb-4">
              <div class="px-5 py-3 border-b border-gray-100">
                <h3 class="font-semibold text-gray-800 text-sm">👥 멤버 {{ members.length }}명</h3>
              </div>
              <div class="px-5 py-4 flex flex-wrap gap-3">
                <div v-for="member in members.slice(0, 12)" :key="member.id"
                  class="flex flex-col items-center gap-1">
                  <div class="w-10 h-10 rounded-full flex items-center justify-center text-sm font-bold text-white"
                    :style="`background: linear-gradient(135deg, ${gradFrom(club.category)}, ${gradTo(club.category)})`">
                    {{ (member.user?.name || member.name || '?')[0] }}
                  </div>
                  <span class="text-[10px] text-gray-500 max-w-[48px] truncate text-center">{{ member.user?.name || member.name }}</span>
                  <span v-if="member.role === 'owner'" class="text-[9px] bg-blue-100 text-blue-600 px-1 rounded">방장</span>
                </div>
                <div v-if="members.length > 12" class="flex flex-col items-center gap-1">
                  <div class="w-10 h-10 rounded-full bg-gray-100 flex items-center justify-center text-xs font-bold text-gray-500">
                    +{{ members.length - 12 }}
                  </div>
                  <span class="text-[10px] text-gray-400">더보기</span>
                </div>
              </div>
            </div>

            <!-- 동호회 정보 -->
            <div class="bg-white rounded-2xl shadow-sm p-5 mb-4">
              <h3 class="font-semibold text-gray-800 text-sm mb-3">📋 동호회 정보</h3>
              <div class="space-y-2 text-sm text-gray-600">
                <div class="flex gap-2">
                  <span class="text-gray-400 w-16 flex-shrink-0">카테고리</span>
                  <span>{{ club.category }}</span>
                </div>
                <div v-if="club.region" class="flex gap-2">
                  <span class="text-gray-400 w-16 flex-shrink-0">지역</span>
                  <span>{{ club.region }}</span>
                </div>
                <div class="flex gap-2">
                  <span class="text-gray-400 w-16 flex-shrink-0">멤버</span>
                  <span>{{ club.member_count || members.length }}명</span>
                </div>
                <div v-if="club.creator" class="flex gap-2">
                  <span class="text-gray-400 w-16 flex-shrink-0">방장</span>
                  <span>{{ club.creator.name }}</span>
                </div>
                <div class="flex gap-2">
                  <span class="text-gray-400 w-16 flex-shrink-0">가입 방식</span>
                  <span>{{ club.is_approval ? '승인제' : '자유 가입' }}</span>
                </div>
              </div>
            </div>

            <router-link to="/clubs" class="text-sm text-gray-500 hover:text-blue-600 transition">
              ← 동호회 목록으로
            </router-link>
          </div>

          <!-- 오른쪽 사이드바: 다른 동호회 -->
          <aside class="hidden lg:block w-72 flex-shrink-0 sticky top-20">
            <div class="bg-white rounded-2xl shadow-sm overflow-hidden">
              <div class="px-4 py-3 border-b border-gray-100 flex items-center justify-between">
                <h3 class="text-sm font-bold text-gray-700">📍 같은 지역 동호회</h3>
                <router-link to="/clubs" class="text-xs text-blue-500 hover:text-blue-600">전체 →</router-link>
              </div>
              <ul v-if="displayClubs.length">
                <li v-for="c in displayClubs" :key="c.id" class="border-b border-gray-50 last:border-0">
                  <router-link :to="'/clubs/' + c.id" class="block px-4 py-3.5 hover:bg-gray-50 transition">
                    <div class="flex items-center gap-3">
                      <div class="w-10 h-10 rounded-xl flex items-center justify-center text-lg flex-shrink-0"
                        :style="`background: linear-gradient(135deg, ${gradFrom(c.category)}, ${gradTo(c.category)})`">
                        {{ categoryEmoji(c.category) }}
                      </div>
                      <div class="flex-1 min-w-0">
                        <p class="text-sm font-semibold text-gray-800 truncate">{{ c.name }}</p>
                        <div class="flex items-center gap-2 text-xs text-gray-400 mt-0.5">
                          <span class="bg-gray-100 px-1.5 py-0.5 rounded text-[10px]">{{ c.category }}</span>
                          <span>👤 {{ c.member_count }}명</span>
                        </div>
                      </div>
                    </div>
                    <p class="text-xs text-gray-500 mt-1.5 line-clamp-2 leading-relaxed">{{ c.description }}</p>
                  </router-link>
                </li>
              </ul>
              <div v-else class="px-4 py-8 text-center text-xs text-gray-400">다른 동호회가 없습니다.</div>
              <div class="px-4 py-3 border-t border-gray-100">
                <button @click="shuffleClubs"
                  class="w-full text-xs text-gray-400 hover:text-blue-600 flex items-center justify-center gap-1 transition">
                  🔄 다른 동호회 보기
                </button>
              </div>
            </div>
          </aside>

        </div>
      </template>

    </div>
  </div>
</template>

<script setup>
import { ref, computed, onMounted, onUnmounted, watch } from 'vue'
import { useRoute, useRouter } from 'vue-router'
import { useAuthStore } from '../../stores/auth'
import axios from 'axios'

const route = useRoute()
const router = useRouter()
const authStore = useAuthStore()

const loading = ref(true)
const club = ref(null)
const members = ref([])
const allOtherClubs = ref([])
const displayClubs = ref([])
let rotateTimer = null

// 카테고리 색상
const catColors = {
  '스포츠':    { from: '#3B82F6', to: '#06B6D4' },
  '음식/요리': { from: '#F97316', to: '#EF4444' },
  '육아/교육': { from: '#8B5CF6', to: '#6366F1' },
  '취미/여가': { from: '#10B981', to: '#06B6D4' },
  '종교':      { from: '#F59E0B', to: '#EF4444' },
  '비즈니스':  { from: '#1D4ED8', to: '#7C3AED' },
  '기타':      { from: '#6B7280', to: '#4B5563' },
}
function gradFrom(cat) { return (catColors[cat] || catColors['기타']).from }
function gradTo(cat)   { return (catColors[cat] || catColors['기타']).to }
function categoryEmoji(cat) {
  const map = { '스포츠': '⚽', '음식/요리': '🍳', '육아/교육': '👶', '취미/여가': '🎨', '종교': '✝️', '비즈니스': '💼', '기타': '👥' }
  return map[cat] || '👥'
}

// 계산값
const isMember = computed(() => {
  if (!authStore.user) return false
  return members.value.some(m => (m.user_id || m.user?.id) === authStore.user.id)
})
const isOwner = computed(() => {
  if (!authStore.user || !club.value) return false
  return club.value.creator_id === authStore.user.id
})

// 사이드바 순환
function shuffleClubs() {
  const shuffled = [...allOtherClubs.value].sort(() => Math.random() - 0.5)
  displayClubs.value = shuffled.slice(0, 5)
}
function startRotation() {
  shuffleClubs()
  rotateTimer = setInterval(shuffleClubs, 6000)
}

// API 호출
async function loadClub() {
  loading.value = true
  club.value = null
  members.value = []
  try {
    const { data } = await axios.get('/api/clubs/' + route.params.id)
    club.value = data.club || data
    members.value = club.value.members || []
  } catch (e) {
    club.value = null
  }
  loading.value = false
}

async function loadOtherClubs() {
  try {
    const { data } = await axios.get('/api/clubs', { params: { per_page: 50 } })
    const list = data.data || data
    const currentId = Number(route.params.id)
    const currentRegion = club.value?.region
    // 같은 지역 우선, 없으면 전체에서 랜덤
    const sameRegion = list.filter(c => c.id !== currentId && c.region === currentRegion)
    const others = list.filter(c => c.id !== currentId)
    allOtherClubs.value = sameRegion.length >= 2 ? sameRegion : others
    startRotation()
  } catch {}
}

// 공유
function shareClub() {
  const url = window.location.href
  if (navigator.share) {
    navigator.share({ title: club.value?.name, url })
  } else if (navigator.clipboard) {
    navigator.clipboard.writeText(url)
    alert('링크가 복사되었습니다.')
  }
}

// 가입 / 탈퇴
async function joinClub() {
  if (!authStore.isLoggedIn) { router.push('/login'); return }
  try {
    await axios.post('/api/clubs/' + club.value.id + '/join')
    alert(club.value.is_approval ? '가입 신청이 완료되었습니다.' : '가입되었습니다!')
    await loadClub()
  } catch (e) {
    alert(e.response?.data?.message || '오류가 발생했습니다.')
  }
}
async function leaveClub() {
  if (!confirm('탈퇴하시겠습니까?')) return
  try {
    await axios.post('/api/clubs/' + club.value.id + '/leave')
    await loadClub()
  } catch (e) {
    alert(e.response?.data?.message || '오류가 발생했습니다.')
  }
}

onMounted(async () => {
  await loadClub()
  loadOtherClubs()
})

onUnmounted(() => {
  if (rotateTimer) clearInterval(rotateTimer)
})

watch(() => route.params.id, async () => {
  if (rotateTimer) clearInterval(rotateTimer)
  await loadClub()
  loadOtherClubs()
})
</script>

<style scoped>
.line-clamp-2 { display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden; }
</style>
